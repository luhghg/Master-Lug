# ─────────────────────────────────────────────────────────────────────────────
# ARETE DISPATCHER — Environment Variables Template
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Master Bot (the bot that owns and manages all sub-bots)
MASTER_BOT_TOKEN=your_master_bot_token_here

# PostgreSQL — use postgresql+asyncpg:// for async driver
DATABASE_URL=postgresql+asyncpg://arete_user:strong_password@db:5432/arete_db

# Redis
REDIS_URL=redis://redis:6379/0

# Public base URL of this server (no trailing slash)
BASE_WEBHOOK_URL=https://yourdomain.com

# Random secret used in X-Telegram-Bot-Api-Secret-Token header
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_WEBHOOK_TOKEN=generate_a_random_secret_here

# Fernet symmetric key for encrypting stored bot tokens
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate_a_fernet_key_here

# Rate limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60
